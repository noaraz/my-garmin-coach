# ---------------------------------------------------------------
# Production secret template.
# cp .env.example .env.prod, then fill in real values.
#
# Local dev: Docker Compose reads a .env file at repo root for variable
# interpolation. Create one with: cp .env.example .env, then fill in values.
# ---------------------------------------------------------------

# Generate with: openssl rand -hex 32  (use a different value for each)
JWT_SECRET=change-me-to-random-32-chars
GARMINCOACH_SECRET_KEY=change-me-to-different-random-32-chars
GARMIN_CREDENTIAL_KEY=change-me-to-another-random-32-chars

# One-time admin setup token — used at /setup to create the first user
BOOTSTRAP_SECRET=change-me-to-random-32-chars

# Neon PostgreSQL connection string (free tier at neon.tech)
# Format: postgresql+asyncpg://user:pass@host.neon.tech/db?ssl=require
DATABASE_URL=postgresql+asyncpg://user:pass@host.neon.tech/db?ssl=require

# Google OAuth client ID — same value used by backend and frontend build
# Create at console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=

# Fixie proxy URL for Garmin OAuth (avoids 429s on shared datacenter IPs)
# Leave empty if not using Fixie. Get URL from usefixie.com.
FIXIE_URL=

# Gemini Flash API key for Plan Coach chat
# Get a free key at aistudio.google.com/apikey (no billing required)
# For Render: set in backend service → Environment tab
GEMINI_API_KEY=
